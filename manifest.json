{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": [
    "tabCapture",
    "offscreen",
    "downloads",
    "activeTab",
    "tabs",
    "notifications",
    "storage"
  ],
  "commands": {
    "toggle-recording": {
      "suggested_key": {
        "default": "Alt+Shift+9",
        "mac": "Alt+Shift+9"
      },
      "description": "__MSG_cmdToggleRecording__"
    },
    "toggle-pause": {
      "suggested_key": {
        "default": "Alt+Shift+8",
        "mac": "Alt+Shift+8"
      },
      "description": "__MSG_cmdTogglePause__"
    }
  }
}
