{
  "manifest_version": 3,
  "name": "Tab Audio Recorder",
  "description": "Record the current tab audio locally as WebM/Opus.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "action": {
    "default_title": "录制当前标签页音频",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "tabCapture",
    "offscreen",
    "downloads",
    "activeTab",
    "tabs",
    "notifications"
  ],
  "commands": {
    "toggle-recording": {
      "suggested_key": {
        "default": "Alt+Shift+9",
        "mac": "Alt+Shift+9"
      },
      "description": "开始 / 停止录制当前标签页音频"
    },
    "toggle-pause": {
      "suggested_key": {
        "default": "Alt+Shift+8",
        "mac": "Alt+Shift+8"
      },
      "description": "暂停 / 继续录音"
    }
  }
}
